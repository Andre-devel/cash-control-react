    {
      "_id": "req_register",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Register",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/register",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"usuario@exemplo.com\",\n  \"password\": \"Senha@123!\",\n  \"consentAccepted\": true\n}"
      },
      "description": "Registra novo usuário. Envia e-mail de verificação."
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Login",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/login",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"usuario@exemplo.com\",\n  \"password\": \"Senha@123!\"\n}"
      },
      "description": "Autentica e retorna accessToken JWT. Copie o token para a variável access_token."
    },
    {
      "_id": "req_logout",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Logout",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/logout",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ access_token }}" }],
      "body": { "mimeType": "application/json", "text": "" },
      "description": "Registra evento de logout. Retorna 204."
    },
    {
      "_id": "req_me_auth",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Get My Profile (auth)",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/auth/me",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ access_token }}" }],
      "description": "Retorna perfil do usuário autenticado (via /auth/me)."
    },
    {
      "_id": "req_change_password",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Change Password",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/password/change",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ access_token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"currentPassword\": \"Senha@123!\",\n  \"newPassword\": \"NovaSenha@456!\"\n}"
      },
      "description": "Troca a senha do usuário logado. Retorna 204."
    },
    {
      "_id": "req_password_reset_request",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Request Password Reset",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/password-reset/request",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"usuario@exemplo.com\"\n}"
      },
      "description": "Envia link de redefinição de senha por e-mail."
    },
    {
      "_id": "req_password_reset_confirm",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Confirm Password Reset",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/password-reset/confirm",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"token\": \"TOKEN_RECEBIDO_POR_EMAIL\",\n  \"newPassword\": \"NovaSenha@456!\"\n}"
      },
      "description": "Conclui redefinição de senha com o token do e-mail."
    },
    {
      "_id": "req_email_verify",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Verify Email",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/auth/email/verify",
      "parameters": [{ "name": "token", "value": "TOKEN_RECEBIDO_POR_EMAIL" }],
      "description": "Verifica o e-mail com o token enviado no link de ativação."
    },
    {
      "_id": "req_email_verify_resend",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Resend Verification Email",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/email/verify/resend",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"usuario@exemplo.com\"\n}"
      },
      "description": "Reenvio do e-mail de verificação."
    },
    {
      "_id": "req_email_change",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Change Email",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/auth/email/change",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ access_token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"newEmail\": \"novoemail@exemplo.com\"\n}"
      },
      "description": "Inicia troca de e-mail. Envia verificação para o novo endereço."
    },
    {
      "_id": "req_unlink_provider",
      "_type": "request",
      "parentId": "fld_auth",
